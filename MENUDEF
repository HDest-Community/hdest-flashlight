AddOptionMenu "OptionsMenu" {
	Submenu "$MENU_HDFL", "HDFL_Flashlight_Settings"
}

AddOptionMenu "HDAddonMenu" {
	Submenu "$MENU_HDFL", "HDFL_Flashlight_Settings"
}

OptionMenu "HDFL_Flashlight_Settings" {
	Title "$HDFL_MENU"
	StaticText ""

	Option "$HDFL_MENU_QUALITY", "hdfl_fl_quality", "Nice_Flashlight_Quality"
	Option "$HDFL_MENU_PARTICLES", "hdfl_fl_particles", "YesNo"
	Control "$HDFL_MENU_TOGGLEKEY", "hdfl_toggleflashlight"
}

OptionValue "Nice_Flashlight_Quality" {
	0, "Simple"
	1, "Fancy"
}
